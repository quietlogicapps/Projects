<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.AllIsOK" parent="Theme.Material3.DayNight.NoActionBar">
    </style>
    <style name="Theme.AllIsOK" parent="Base.Theme.AllIsOK">
        <item name="colorPrimary">@color/expirely_primary</item>
        <item name="colorOnPrimary">@color/expirely_onPrimary</item>
        <item name="android:statusBarColor">@color/expirely_primary</item>
        <item name="popupMenuStyle">@style/Widget.AllIsOK.PopupMenu</item>
        <item name="actionOverflowMenuStyle">@style/Widget.AllIsOK.PopupMenu</item>
    </style>
    <style name="Widget.AllIsOK.PopupMenu" parent="Widget.Material3.PopupMenu">
        <item name="android:popupBackground">@drawable/bg_rounded_popup</item>
        <item name="android:popupElevation">12dp</item>
    </style>
    <style name="CutCornersButton">
        <item name="cornerFamily">cut</item>
        <item name="cornerSize">28dp</item>
    </style>
    <style name="CutCornersButton_TopLeft">
        <item name="cornerFamilyTopLeft">cut</item>
        <item name="cornerFamilyTopRight">rounded</item>
        <item name="cornerFamilyBottomLeft">rounded</item>
        <item name="cornerFamilyBottomRight">rounded</item>
        <item name="cornerSizeTopLeft">28dp</item>
    </style>
    <style name="CutCornersButton_TopRight">
        <item name="cornerFamilyTopLeft">rounded</item>
        <item name="cornerFamilyTopRight">cut</item>
        <item name="cornerFamilyBottomLeft">rounded</item>
        <item name="cornerFamilyBottomRight">rounded</item>
        <item name="cornerSizeTopRight">28dp</item>
    </style>
    <style name="CutCornersButton_BottomLeft">
        <item name="cornerFamilyTopLeft">rounded</item>
        <item name="cornerFamilyTopRight">rounded</item>
        <item name="cornerFamilyBottomLeft">cut</item>
        <item name="cornerFamilyBottomRight">rounded</item>
        <item name="cornerSizeBottomLeft">28dp</item>
    </style>
    <style name="CutCornersButton_BottomRight">
        <item name="cornerFamilyTopLeft">rounded</item>
        <item name="cornerFamilyTopRight">rounded</item>
        <item name="cornerFamilyBottomLeft">rounded</item>
        <item name="cornerFamilyBottomRight">cut</item>
        <item name="cornerSizeBottomRight">28dp</item>
    </style>
</resources>
