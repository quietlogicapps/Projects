<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/viewAdminIndicator"
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:background="@android:color/holo_red_dark"
        android:gravity="center"
        android:text="ADMIN MODE ACTIVE"
        android:textColor="@android:color/white"
        android:textSize="12sp"
        android:textStyle="bold"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/textEmergencyTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Emergency Info"
        android:textSize="22sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/buttonEditEmergencyInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Edit" />

    <TextView
        android:id="@+id/textBloodType"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Blood type: -" />

    <TextView
        android:id="@+id/textAllergies"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Allergies: -" />

    <TextView
        android:id="@+id/textConditions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Conditions: -" />

    <TextView
        android:id="@+id/textNotes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Notes: -" />

    <TextView
        android:id="@+id/textRecentTakenTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Recent Taken (72H)"
        android:textSize="22sp"
        android:textStyle="bold" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerRecentTaken"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        tools:listitem="@layout/item_recent_taken" />

</LinearLayout>