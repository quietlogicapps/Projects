<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/bg_home_gradient">

    <TextView
        android:id="@+id/viewAdminIndicator"
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:background="@android:color/holo_red_dark"
        android:gravity="center"
        android:text="@string/admin_mode_active"
        android:textColor="@android:color/white"
        android:textSize="12sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <TextView
        android:id="@+id/textEmergencyTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textAlignment="center"
        android:text="@string/emergency_info_title"
        android:textSize="22sp"
        android:textStyle="bold" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonEditEmergencyInfo"
        android:layout_width="160dp"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:layout_gravity="center"
        android:letterSpacing="0.03"
        android:text="@string/edit"
        android:textAllCaps="false"
        android:textColor="@color/expirely_onPrimary"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="@color/expirely_primary"
        app:cornerRadius="18dp"
        app:elevation="8dp" />

    <TextView
        android:id="@+id/textBloodType"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:text="@string/blood_type"
        android:textAlignment="center"
        android:textSize="17sp"
        android:textColor="#2E2E2E" />

    <TextView
        android:id="@+id/textAllergies"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:text="@string/allergies"
        android:textAlignment="center"
        android:textSize="17sp"
        android:textColor="#2E2E2E" />

    <TextView
        android:id="@+id/textConditions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:text="@string/conditions"
        android:textAlignment="center"
        android:textSize="17sp"
        android:textColor="#2E2E2E" />

    <TextView
        android:id="@+id/textNotes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:text="@string/notes"
        android:textAlignment="center"
        android:textSize="17sp"
        android:textColor="#2E2E2E" />

    <View
        android:layout_width="120dp"
        android:layout_height="1dp"
        android:layout_marginTop="20dp"
        android:layout_gravity="center"
        android:background="#33000000" />

    <TextView
        android:id="@+id/textRecentTakenTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:textAlignment="center"
        android:text="@string/recent_taken_title"
        android:textSize="22sp"
        android:textStyle="bold" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerRecentTaken"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        android:fadeScrollbars="false"
        android:scrollbarStyle="insideInset"
        android:scrollbars="vertical"
        tools:listitem="@layout/item_recent_taken" />

</LinearLayout>