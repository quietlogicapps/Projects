<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Care Item Name"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/inputName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Example: Blood pressure medicine"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Instruction"
            android:textSize="16sp" />

        <RadioGroup
            android:id="@+id/groupInstruction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <RadioButton
                android:id="@+id/radioNone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="None"
                android:checked="true"/>

            <RadioButton
                android:id="@+id/radioBefore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Before food"
                android:layout_marginStart="16dp"/>

            <RadioButton
                android:id="@+id/radioAfter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="After food"
                android:layout_marginStart="16dp"/>

        </RadioGroup>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Repeat"
            android:textSize="16sp" />

        <RadioGroup
            android:id="@+id/groupRepeat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <RadioButton
                android:id="@+id/radioDaily"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Daily"
                android:checked="true"/>

            <RadioButton
                android:id="@+id/radioSpecific"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Specific days"
                android:layout_marginStart="16dp"/>

        </RadioGroup>

        <Button
            android:id="@+id/btnPickDays"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PICK DAYS"
            android:visibility="gone"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/textRepeatDays"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Days: Daily"
            android:textSize="16sp"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btnPickStart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PICK START DATE"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/textStart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Start: not set"
            android:textSize="16sp"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnPickEnd"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PICK END DATE"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/textEnd"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="End: not set"
            android:textSize="16sp"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btnAddTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ADD TIME"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/textTimes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No times added"
            android:textSize="16sp"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btnSaveCare"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SAVE"/>

    </LinearLayout>

</ScrollView>