<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_home_gradient">

    <TextView
        android:id="@+id/viewAdminIndicator"
        android:layout_width="0dp"
        android:layout_height="28dp"
        android:background="@android:color/holo_red_dark"
        android:gravity="center"
        android:text="@string/admin_mode_active"
        android:textColor="@android:color/white"
        android:textSize="12sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <GridLayout
        android:id="@+id/contactButtonsContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:rowCount="2"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/viewAdminIndicator"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonRelative"
            android:layout_width="0dp"
            android:layout_height="230dp"
            android:layout_columnWeight="1"
            android:layout_margin="10dp"
            android:letterSpacing="0.03"
            android:text="@string/contact_relative"
            android:textAllCaps="false"
            android:textColor="@color/expirely_onPrimary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:hyphenationFrequency="none"
            app:backgroundTint="@color/expirely_primary"
            app:cornerRadius="18dp"
            app:elevation="8dp"
            app:shapeAppearanceOverlay="@style/CutCornersButton_BottomRight" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonDoctor"
            android:layout_width="0dp"
            android:layout_height="230dp"
            android:layout_columnWeight="1"
            android:layout_margin="10dp"
            android:letterSpacing="0.03"
            android:text="@string/contact_doctor"
            android:textAllCaps="false"
            android:textColor="@color/expirely_onPrimary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:hyphenationFrequency="none"
            app:backgroundTint="@color/expirely_primary"
            app:cornerRadius="18dp"
            app:elevation="8dp"
            app:shapeAppearanceOverlay="@style/CutCornersButton_BottomLeft" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonContact3"
            android:layout_width="0dp"
            android:layout_height="230dp"
            android:layout_columnWeight="1"
            android:layout_margin="10dp"
            android:letterSpacing="0.03"
            android:text="@string/contact_3"
            android:textAllCaps="false"
            android:textColor="@color/expirely_onPrimary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:hyphenationFrequency="none"
            app:backgroundTint="@color/expirely_primary"
            app:cornerRadius="18dp"
            app:elevation="8dp"
            app:shapeAppearanceOverlay="@style/CutCornersButton_TopRight" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonEmergency"
            android:layout_width="0dp"
            android:layout_height="230dp"
            android:layout_columnWeight="1"
            android:layout_margin="10dp"
            android:letterSpacing="0.03"
            android:text="@string/contact_emergency"
            android:textAllCaps="false"
            android:textColor="@color/expirely_onPrimary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:hyphenationFrequency="none"
            app:backgroundTint="@color/expirely_primary"
            app:cornerRadius="18dp"
            app:elevation="8dp"
            app:shapeAppearanceOverlay="@style/CutCornersButton_TopLeft" />

    </GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout>