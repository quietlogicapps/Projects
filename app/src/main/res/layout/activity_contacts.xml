<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_home_gradient">

    <TextView
        android:id="@+id/viewAdminIndicator"
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:background="@android:color/holo_red_dark"
        android:gravity="center"
        android:text="@string/admin_mode_active"
        android:textColor="@android:color/white"
        android:textSize="12sp"
        android:textStyle="bold"
        android:visibility="gone"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

        <Button
            android:id="@+id/buttonRelative"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:text="@string/contact_relative"
            android:textSize="20sp"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/buttonDoctor"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:text="@string/contact_doctor"
            android:textSize="20sp"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/buttonContact3"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:text="@string/contact_3"
            android:textSize="20sp"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/buttonEmergency"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:text="@string/contact_emergency"
            android:textSize="20sp"/>

    </LinearLayout>

</LinearLayout>