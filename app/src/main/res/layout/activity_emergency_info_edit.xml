<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_home_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/textEditEmergencyTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/edit_emergency_title"
            android:textSize="22sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/editBloodType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/hint_blood_type"
            android:inputType="textCapWords" />

        <EditText
            android:id="@+id/editAllergies"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/hint_allergies"
            android:inputType="textMultiLine"
            android:minLines="3"
            android:gravity="top|start" />

        <EditText
            android:id="@+id/editConditions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/hint_conditions"
            android:inputType="textMultiLine"
            android:minLines="3"
            android:gravity="top|start" />

        <EditText
            android:id="@+id/editNotes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/hint_notes"
            android:inputType="textMultiLine"
            android:minLines="4"
            android:gravity="top|start" />

        <Button
            android:id="@+id/buttonSaveEmergencyInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/save" />

        <Button
            android:id="@+id/buttonClearEmergencyInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/clear" />

    </LinearLayout>

</ScrollView>