<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_home_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/textEditEmergencyTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:textAlignment="center"
            android:text="@string/edit_emergency_title"
            android:textColor="#111827"
            android:textSize="22sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/editBloodType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:hint="@string/hint_blood_type"
            android:inputType="textCapWords"
            android:textColor="#1F2937"
            android:textColorHint="#4B5563" />

        <EditText
            android:id="@+id/editAllergies"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="top|start"
            android:hint="@string/hint_allergies"
            android:inputType="textMultiLine"
            android:minLines="3"
            android:textColor="#1F2937"
            android:textColorHint="#4B5563" />

        <EditText
            android:id="@+id/editConditions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="top|start"
            android:hint="@string/hint_conditions"
            android:inputType="textMultiLine"
            android:minLines="3"
            android:textColor="#1F2937"
            android:textColorHint="#4B5563" />

        <EditText
            android:id="@+id/editNotes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="top|start"
            android:hint="@string/hint_notes"
            android:inputType="textMultiLine"
            android:minLines="4"
            android:textColor="#1F2937"
            android:textColorHint="#4B5563" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonSaveEmergencyInfo"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="36dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="@string/save"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:textStyle="bold"
            app:cornerRadius="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonClearEmergencyInfo"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="44dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="@string/clear"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:textStyle="bold"
            app:cornerRadius="16dp" />

    </LinearLayout>

</ScrollView>