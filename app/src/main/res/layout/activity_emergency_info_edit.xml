<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/textEditEmergencyTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Edit Emergency Info"
            android:textSize="22sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/editBloodType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="Blood type"
            android:inputType="textCapWords" />

        <EditText
            android:id="@+id/editAllergies"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Allergies"
            android:inputType="textMultiLine"
            android:minLines="3"
            android:gravity="top|start" />

        <EditText
            android:id="@+id/editConditions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Conditions"
            android:inputType="textMultiLine"
            android:minLines="3"
            android:gravity="top|start" />

        <EditText
            android:id="@+id/editNotes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Notes"
            android:inputType="textMultiLine"
            android:minLines="4"
            android:gravity="top|start" />

        <Button
            android:id="@+id/buttonSaveEmergencyInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Save" />

        <Button
            android:id="@+id/buttonClearEmergencyInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Clear" />

    </LinearLayout>

</ScrollView>