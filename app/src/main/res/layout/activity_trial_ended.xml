<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="@drawable/bg_home_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="80dp">

        <TextView
            android:id="@+id/lockMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/trial_title"
            android:textColor="@color/allisok_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textAlignment="center"
            android:layout_marginBottom="32dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="40dp"
            android:layout_marginEnd="40dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBuy"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="@string/trial_buy"
                android:textAllCaps="false"
                android:textColor="@color/allisok_onPrimary"
                android:textSize="18sp"
                android:textStyle="bold"
                app:backgroundTint="@color/allisok_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRestore"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="24dp"
                android:text="@string/trial_restore"
                android:textAllCaps="false"
                android:textColor="@color/allisok_onPrimary"
                android:textSize="18sp"
                android:textStyle="bold"
                app:backgroundTint="@color/allisok_primary" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
