<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/bg_home_gradient">

    <TextView
        android:id="@+id/textImportTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/import_title"
        android:textSize="24sp"
        android:textStyle="bold" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonLoadBackup"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="16dp"
        android:text="@string/import_load"
        android:textAllCaps="false"
        android:textSize="18sp"
        android:textStyle="bold"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:backgroundTint="?attr/colorPrimary"
        app:cornerRadius="16dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <TextView
            android:id="@+id/textImportPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/import_empty"
            android:textIsSelectable="true"
            android:textSize="16sp"
            android:textStyle="bold" />
    </ScrollView>

</LinearLayout>