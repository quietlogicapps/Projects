<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_home_gradient">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarHome"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="@color/expirely_primary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/textToolbarTitle"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="@string/app_name"
            android:textColor="@color/expirely_onPrimary"
            android:textSize="22sp"
            android:textStyle="bold" />
    </androidx.appcompat.widget.Toolbar>

    <TextView
        android:id="@+id/viewAdminIndicator"
        android:layout_width="0dp"
        android:layout_height="28dp"
        android:background="@android:color/holo_red_dark"
        android:gravity="center"
        android:text="@string/admin_mode_active"
        android:textColor="@android:color/white"
        android:textSize="12sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/toolbarHome"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/homeButtonsContainer"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/viewAdminIndicator"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.44">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonContacts"
            android:layout_width="280dp"
            android:layout_height="88dp"
            android:letterSpacing="0.03"
            android:text="@string/home_contacts"
            android:textAllCaps="false"
            android:textColor="@color/expirely_onPrimary"
            android:textSize="20sp"
            android:textStyle="bold"
            app:backgroundTint="@color/expirely_primary"
            app:cornerRadius="18dp"
            app:elevation="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonCare"
            android:layout_width="280dp"
            android:layout_height="88dp"
            android:layout_marginTop="28dp"
            android:letterSpacing="0.03"
            android:text="@string/home_care"
            android:textAllCaps="false"
            android:textColor="@color/expirely_onPrimary"
            android:textSize="20sp"
            android:textStyle="bold"
            app:backgroundTint="@color/expirely_primary"
            app:cornerRadius="18dp"
            app:elevation="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonInfo"
            android:layout_width="280dp"
            android:layout_height="88dp"
            android:layout_marginTop="28dp"
            android:letterSpacing="0.03"
            android:text="@string/home_info"
            android:textAllCaps="false"
            android:textColor="@color/expirely_onPrimary"
            android:textSize="20sp"
            android:textStyle="bold"
            app:backgroundTint="@color/expirely_primary"
            app:cornerRadius="18dp"
            app:elevation="8dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>