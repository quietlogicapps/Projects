<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/bg_home_gradient">

    <TextView
        android:id="@+id/viewAdminIndicator"
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:background="@android:color/holo_red_dark"
        android:gravity="center"
        android:text="@string/admin_mode_active"
        android:textColor="@android:color/white"
        android:textSize="12sp"
        android:textStyle="bold"
        android:visibility="gone"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAddCare"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginBottom="16dp"
        android:text="@string/care_add"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:textStyle="bold"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:backgroundTint="?attr/colorPrimary"
        app:cornerRadius="16dp"/>

    <TextView
        android:id="@+id/textEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/care_empty"
        android:textSize="18sp"
        android:gravity="center"
        android:layout_marginTop="40dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerCare"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="vertical"
        android:fadeScrollbars="false"
        android:scrollbarStyle="insideInset" />

</LinearLayout>