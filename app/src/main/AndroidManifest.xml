<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Notifications (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Exact alarms (Android 12+ special access) -->
    <uses-permission
        android:name="android.permission.SCHEDULE_EXACT_ALARM"
        tools:targetApi="s" />

    <!-- For reschedule after reboot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AllIsOK"
        tools:targetApi="31">

        <!-- ENTRY GATE -->
        <activity
            android:name=".PermissionSetupActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".ui.home.HomeActivity" android:exported="false" />
        <activity android:name=".ui.contacts.ContactsActivity" android:exported="false" />
        <activity android:name=".ui.contacts.ContactEditActivity" android:exported="false" />
        <activity android:name=".ui.care.CareActivity" android:exported="false" />
        <activity android:name=".ui.care.CareEditActivity" android:exported="false" />
        <activity android:name=".ui.info.InfoActivity" android:exported="false" />
        <activity android:name=".ui.settings.SettingsActivity" android:exported="false" />

        <receiver
            android:name=".alarm.receiver.AlarmReceiver"
            android:exported="false" />

    </application>

</manifest>